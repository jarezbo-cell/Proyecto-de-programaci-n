import customtkinter as ctk  # Importa la librería para crear interfaces gráficas modernas
from tkinter import messagebox  # Importa las ventanas emergentes nativas (alertas, advertencias)
import sqlite3  # Importa el módulo para gestionar la base de datos SQLite
import os  # Importa el módulo del sistema operativo (para manejo de rutas si se requiere)

# ==========================================================
# 1. CONSTANTES Y CONFIGURACIONES GLOBALES
# ==========================================================
# Ruta absoluta hacia el archivo de la base de datos local
RUTA_BD = "C:\\Users\\angel\\Desktop\\BD Despacho\\BD despacho.db"

# Listas de tuplas que definen el (Texto, Icono) de los botones laterales según cada rol
BOTONES_JEFE = [("DAR DE ALTA O BAJA USUARIOS", "👥"), ("ASIGNAR CASO", "⚖️"), ("PAGO DE NOMINA DE EMPLEADOS", "🪙")]
BOTONES_PASANTE = [("REVISAR CASO", "🔍"), ("SUBIR CASO", "🔼"), ("REDACTAR RECADO", "✍️")]
BOTONES_ABOGADO = [("VER EXPEDIENTE", "📁"), ("VER RECADO", "✉️"), ("REGISTRAR ASESORÍA", "📝"), ("AGENDAR AUDIENCIA", "📅")]


# ==========================================================
# 2. FUNCIONES DE LÓGICA (CONTROLADORES)
# ==========================================================
def validar_login(ventana_login, usuario, password):
    u = usuario.strip()  # Elimina espacios en blanco innecesarios al inicio y final del usuario
    p = password.strip()  # Elimina espacios en blanco innecesarios al inicio y final de la contraseña
    
    if not u or not p:  # Si alguno de los campos se quedó vacío tras el strip
        messagebox.showwarning("Advertencia", "Por favor, llene todos los campos.")  # Muestra una alerta
        return  # Interrumpe la función para que no continúe con la validación

    try:
        conexion = sqlite3.connect(RUTA_BD)  # Abre la conexión con el archivo de la base de datos
        cursor = conexion.cursor()  # Crea el cursor para ejecutar las sentencias SQL
        
        # Ejecuta la consulta limpiando espacios y asegurando minúsculas con LOWER y TRIM
        cursor.execute(
            "SELECT IDU, NOMBRE, CONTRASEÑA, ROL FROM Usuarios WHERE LOWER(TRIM(IDU)) = LOWER(?) AND LOWER(TRIM(CONTRASEÑA)) = ?", 
            (u, p)
        )
        resultado = cursor.fetchone()  # Recupera el primer registro que coincida con la consulta
        conexion.close()  # Cierra la conexión de forma segura para liberar el archivo de la BD
        
        # Mensajes de depuración enviados directamente a la consola de comandos (terminal)
        print(f"\n[BD INFO] Buscando -> Usuario introducido: '{u}' | Clave introducida: '{p}'")
        print(f"[BD INFO] Resultado devuelto por la Base de Datos: {resultado}")
        
        if resultado:  # Si la base de datos devolvió un registro válido (las credenciales existen)
            idu_bd, nombre_bd, _, rol_bd = resultado  # Desempaqueta los valores de la fila obtenida
            datos_usuario = {"idu": idu_bd, "nombre": str(nombre_bd).upper()}  # Guarda datos en un diccionario en mayúsculas
            rol_bd = str(rol_bd).upper().strip()  # Convierte el rol a mayúsculas limpias
            
            ventana_login.destroy()  # Cierra por completo la ventana de inicio de sesión actual
            
            # Condicional para evaluar el rol y desplegar el menú que le corresponde
            if "JEFE" in rol_bd or "SUPERUSUARIO" in rol_bd:
                abrir_tablero(f'{rol_bd}', "INFORMACIÓN DEL JEFE", BOTONES_JEFE, datos_usuario, mostrar_pestanas=True)
            elif "PASANTE" in rol_bd:
                abrir_tablero("PASANTE", "INFORMACIÓN DEL PASANTE", BOTONES_PASANTE, datos_usuario, mostrar_pestanas=False)
            elif "ABOGADO" in rol_bd:
                abrir_tablero("ABOGADO", "INFORMACIÓN DEL ABOGADO", BOTONES_ABOGADO, datos_usuario, mostrar_pestanas=False)
            else:  # Si el rol existe en la BD pero no está mapeado en la lógica de las interfaces anteriores
                messagebox.showerror("Error", f"El Rol '{rol_bd}' encontrado no coincide con las directivas del sistema.")
                crear_login()  # Redirige nuevamente al login seguro
        else:  # Si no se encontró ninguna coincidencia en la base de datos
            messagebox.showerror("Error de Credenciales", "ID de Empleado o Contraseña incorrectos.")
            
    except sqlite3.OperationalError as e:  # Atrapa fallos específicos (como que la ruta de la BD esté mal o el archivo bloqueado)
        messagebox.showerror("Error de BD", f"No se pudo establecer conexión o lectura con el archivo .db\nDetalle: {e}")


# ==========================================================
# 3. INTERFACES GRÁFICAS (VISTAS)
# ==========================================================

# --- PANTALLA PRINCIPAL DEL SISTEMA (TABLERO JURÍDICO) ---
def abrir_tablero(rol, titulo_tarjeta, botones_lista, datos_usuario, mostrar_pestanas=False):
    ventana_tablero = ctk.CTk()  # Instancia la ventana principal del panel
    ventana_tablero.title(f"Sistema Integral Jurídico - {rol}")  # Asigna el título dinámico a la barra superior
    ventana_tablero.geometry("1100x650")  # Define el ancho por alto de la interfaz en píxeles
    ctk.set_appearance_mode("light")  # Configura de manera explícita el modo claro para esta ventana
    ventana_tablero.configure(fg_color="#EFE7DC")  # Coloca el color de fondo beige claro exterior

    # ------------------------------------------------------
    # A. CONTENEDORES (FRAMES)
    # ------------------------------------------------------
    # Contenedor central oscuro que aloja todo el diseño interior
    ventana_base = ctk.CTkFrame(master=ventana_tablero, fg_color="#3E2723", corner_radius=15)
    ventana_base.pack(pady=40, padx=40, fill="both", expand=True)

    # Frame del menú lateral izquierdo donde irán las opciones del empleado
    menu_lateral = ctk.CTkFrame(master=ventana_base, fg_color="#3E2723", width=280)
    menu_lateral.pack(side="left", fill="y", padx=20, pady=20)
    menu_lateral.pack_propagate(False)  # Evita que el contenedor se achique al tamaño de sus componentes internos

    # Tarjeta con fondo marrón claro dedicada a mostrar el perfil del usuario activo
    tarjeta_info = ctk.CTkFrame(master=menu_lateral, fg_color="#5D4037", corner_radius=10)
    tarjeta_info.pack(fill="x", padx=10, pady=(0, 20))

    # Panel blanco/gris claro del lado derecho donde se desplegarán las actividades dinámicas
    panel_derecho = ctk.CTkFrame(master=ventana_base, fg_color="#F9F8F6", corner_radius=12)
    panel_derecho.pack(side="right", fill="both", expand=True, padx=(0, 20), pady=20)

    # ------------------------------------------------------
    # B. ETIQUETAS E INFORMACIÓN FIJA DEL MENÚ LATERAL
    # ------------------------------------------------------
    lbl_logo_lateral = ctk.CTkLabel(master=menu_lateral, text="⚖️", font=("Arial", 32), text_color="#EFE7DC")
    lbl_logo_lateral.pack(pady=(10, 2))
    
    lbl_titulo_lateral = ctk.CTkLabel(master=menu_lateral, text="BUFETE JURÍDICO & ASOCIADOS", font=("Arial", 10, "bold"), text_color="#C2BCB4")
    lbl_titulo_lateral.pack(pady=(0, 15))

    lbl_titulo_tarjeta = ctk.CTkLabel(master=tarjeta_info, text=titulo_tarjeta, font=("Arial", 9, "bold"), text_color="#EFE7DC")
    lbl_titulo_tarjeta.pack(pady=(10, 8))
    
    lbl_avatar = ctk.CTkLabel(master=tarjeta_info, text="👤", font=("Arial", 24), fg_color="#EFE7DC", text_color="#3E2723", width=40, height=40, corner_radius=20)
    lbl_avatar.pack(pady=(0, 10))

    lbl_nombre = ctk.CTkLabel(master=tarjeta_info, text=f"Nombre: {datos_usuario['nombre']}", font=("Arial", 11), text_color="#FFF", anchor="w")
    lbl_nombre.pack(fill="x", padx=20, pady=2)
    
    lbl_id = ctk.CTkLabel(master=tarjeta_info, text=f"ID Empleado: {datos_usuario['idu']}", font=("Arial", 11), text_color="#FFF", anchor="w")
    lbl_id.pack(fill="x", padx=20, pady=2)
    
    lbl_rol = ctk.CTkLabel(master=tarjeta_info, text=f"Rol: {rol}", font=("Arial", 11), text_color="#FFF", anchor="w")
    lbl_rol.pack(fill="x", padx=20, pady=2)
    
    lbl_espacio = ctk.CTkLabel(master=tarjeta_info, text="")
    lbl_espacio.pack(pady=2)

    # ------------------------------------------------------
    # C. CONTROLADORES DE FLUJO INTERNOS (CAMBIO DE VISTAS)
    # ------------------------------------------------------
    def limpiar_panel_derecho():
        """Elimina de forma radical todos los widgets del recuadro blanco para redibujar cosas nuevas"""
        for widget in panel_derecho.winfo_children():
            widget.destroy()

    def mostrar_vista_inicio():
        """Dibuja la vista base del panel derecho (Título predeterminado, buscador y cerrar sesión)"""
        limpiar_panel_derecho()
        
        # Título principal del panel derecho
        lbl_panel_titulo = ctk.CTkLabel(master=panel_derecho, text=f"PANEL PRINCIPAL - {rol}", font=("Times New Roman", 24, "bold"), text_color="#1F1711")
        lbl_panel_titulo.pack(anchor="w", padx=40, pady=(40, 15))

        # Botón rojo ubicado en la esquina inferior derecha para salir del sistema
        btn_cerrar_sesion = ctk.CTkButton(
            master=panel_derecho, text="🛑 CERRAR SESIÓN", fg_color="#B71C1C", hover_color="#9A1B1B", 
            text_color="#FFFFFF", font=("Arial", 12, "bold"), height=38, corner_radius=8, command=cerrar_sesion
        )
        btn_cerrar_sesion.pack(side="bottom", anchor="se", padx=40, pady=40)

    def mostrar_formulario_alta():
        """Remueve el buscador e inserta los cuadros de texto para registro directamente en el panel blanco"""
        limpiar_panel_derecho()

        # Título interno del formulario
        ctk.CTkLabel(master=panel_derecho, text="👥 ADMINISTRACIÓN DE PERSONAL (ALTA / BAJA)", font=("Times New Roman", 22, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(40, 5))
        ctk.CTkLabel(master=panel_derecho, text="Para dar de ALTA complete todos los campos. Para dar de BAJA ingrese únicamente el ID de Empleado.", font=("Arial", 11), text_color="#5D4037").pack(anchor="w", padx=40, pady=(0, 20))

        # Contenedor transparente interno para estructurar los campos
        form_container = ctk.CTkFrame(master=panel_derecho, fg_color="transparent")
        form_container.pack(fill="both", expand=True, padx=40)

        # Entrada: ID Empleado
        ctk.CTkLabel(master=form_container, text="ID de Empleado (Usuario)", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", pady=(5, 2))
        txt_id = ctk.CTkEntry(master=form_container, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=350, height=35)
        txt_id.pack(anchor="w", pady=(0, 15))

        # Entrada: Nombre Completo
        ctk.CTkLabel(master=form_container, text="Nombre Completo", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", pady=(5, 2))
        txt_nombre = ctk.CTkEntry(master=form_container, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=350, height=35)
        txt_nombre.pack(anchor="w", pady=(0, 15))

        # Entrada: Contraseña
        ctk.CTkLabel(master=form_container, text="Contraseña Temporal", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", pady=(5, 2))
        txt_pass = ctk.CTkEntry(master=form_container, show="*", fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=350, height=35)
        txt_pass.pack(anchor="w", pady=(0, 15))

        # Menú Desplegable: Rol
        ctk.CTkLabel(master=form_container, text="Seleccionar Rol en el Bufete", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", pady=(5, 2))
        combo_rol = ctk.CTkComboBox(master=form_container, values=["ABOGADO", "PASANTE", "JEFE"], fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", button_color="#4A311E", width=350, height=35)
        combo_rol.pack(anchor="w", pady=(0, 30))
        combo_rol.set("PASANTE")

        # Función para procesar el guardado SQL (ALTA)
        def registrar_usuario_bd():
            idu = txt_id.get().strip()
            nombre = txt_nombre.get().strip()
            contra = txt_pass.get().strip()
            rol_elegido = combo_rol.get()

            if not idu or not nombre or not contra:
                messagebox.showwarning("Campos vacíos", "Por favor, complete todos los campos para dar de alta.")
                return

            try:
                conexion = sqlite3.connect(RUTA_BD)
                cursor = conexion.cursor()
                cursor.execute(
                    "INSERT INTO Usuarios (IDU, NOMBRE, CONTRASEÑA, ROL) VALUES (?, ?, ?, ?)",
                    (idu, nombre, contra, rol_elegido)
                )
                conexion.commit()
                conexion.close()

                messagebox.showinfo("Éxito", f"¡Usuario '{nombre}' guardado exitosamente!")
                mostrar_vista_inicio()
                
            except sqlite3.IntegrityError:
                messagebox.showerror("Error", f"El ID de Empleado '{idu}' ya está registrado.")
            except Exception as e:
                messagebox.showerror("Error de BD", f"Error inesperado: {e}")

        # Función para procesar la eliminación SQL (BAJA)
        def dar_de_baja_bd():
            idu = txt_id.get().strip()

            if not idu:
                messagebox.showwarning("Falta ID", "Por favor, ingrese el ID de Empleado que desea dar de baja.")
                return

            # Ventana de confirmación de seguridad antes de borrar de la base de datos
            confirmar = messagebox.askyesno("Confirmar Baja", f"¿Está seguro de que desea eliminar permanentemente al empleado con ID: '{idu}'?")
            if not confirmar:
                return

            try:
                conexion = sqlite3.connect(RUTA_BD)
                cursor = conexion.cursor()
                
                # Primero verificamos si el usuario realmente existe en la BD
                cursor.execute("SELECT NOMBRE FROM Usuarios WHERE LOWER(TRIM(IDU)) = LOWER(?)", (idu,))
                usuario_existe = cursor.fetchone()
                
                if not usuario_existe:
                    messagebox.showerror("No encontrado", f"No se encontró ningún empleado con el ID '{idu}' en el sistema.")
                    conexion.close()
                    return

                # Si existe, procedemos al borrado seguro
                cursor.execute("DELETE FROM Usuarios WHERE LOWER(TRIM(IDU)) = LOWER(?)", (idu,))
                conexion.commit()
                conexion.close()

                messagebox.showinfo("Eliminado", f"¡El empleado '{usuario_existe[0]}' ha sido dado de baja correctamente!")
                mostrar_vista_inicio()  # Refresca la vista regresando al inicio

            except Exception as e:
                messagebox.showerror("Error de BD", f"No se pudo completar la baja en la base de datos:\n{e}")

        # Bloque inferior para botones de acción (Guardar, Dar de Baja y Cancelar)
        fila_acciones = ctk.CTkFrame(master=form_container, fg_color="transparent")
        fila_acciones.pack(anchor="w", pady=10)

        # Botón Café de Guardar (Alta)
        btn_guardar = ctk.CTkButton(master=fila_acciones, text="💾 GUARDAR ALTA", font=("Arial", 12, "bold"), fg_color="#4A311E", hover_color="#362315", text_color="#FFFFFF", height=40, width=150, command=registrar_usuario_bd)
        btn_guardar.pack(side="left", padx=(0, 10))

        # Botón Rojo de Dar de Baja (Baja) - ¡NUEVO!
        btn_baja = ctk.CTkButton(master=fila_acciones, text="🗑️ DAR DE BAJA", font=("Arial", 12, "bold"), fg_color="#B71C1C", hover_color="#9A1B1B", text_color="#FFFFFF", height=40, width=150, command=dar_de_baja_bd)
        btn_baja.pack(side="left", padx=(0, 15))

        # Botón Gris para Cancelar
        btn_cancelar = ctk.CTkButton(master=fila_acciones, text="❌ CANCELAR", font=("Arial", 12, "bold"), fg_color="#C2BCB4", hover_color="#A8A29A", text_color="#1F1711", height=40, width=100, command=mostrar_vista_inicio)
        btn_cancelar.pack(side="left")

    # ------------------------------------------------------
    # D. GENERACIÓN DINÁMICA DE BOTONES LATERALES
    # ------------------------------------------------------
    for texto, icono in botones_lista:
        comando_boton = None
        
        # Enlaza la acción únicamente si el botón coincide con la directiva del Jefe
        if texto == "DAR DE ALTA O BAJA USUARIOS":
            comando_boton = mostrar_formulario_alta

        btn_menu = ctk.CTkButton(
            master=menu_lateral, text=f"{icono}   {texto}", anchor="w",
            fg_color="#4E342E", hover_color="#5D4037", border_color="#6D4C41",
            border_width=1, height=40, corner_radius=8, font=("Arial", 11, "bold"), 
            text_color="#EFE7DC", command=comando_boton
        )
        btn_menu.pack(fill="x", padx=10, pady=5)

    # Función interna anidada encargada de cerrar la sesión actual
    def cerrar_sesion():
        ventana_tablero.destroy()
        crear_login()

    # Carga inicial por defecto en el panel blanco al abrir el sistema
    mostrar_vista_inicio()
    ventana_tablero.mainloop()


