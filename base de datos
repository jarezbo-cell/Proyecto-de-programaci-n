# 3. INTERFAZ GRÁFICA DEL LOGIN (VENTANA DE INICIO)
# ==========================================================
def crear_login():
    app_login = ctk.CTk()
    app_login.title("Sistema Integral Jurídico - Inicio de Sesión")
    app_login.geometry("500x650")
    ctk.set_appearance_mode("light") 
    app_login.configure(fg_color="#EFE7DC")

    # Contenedor Central del Login
    ventana = ctk.CTkFrame(master=app_login, fg_color="#F9F8F6", border_color="#C2BCB4", border_width=1, corner_radius=10)
    ventana.pack(pady=50, padx=40, fill="both", expand=True)

    # Encabezado visual
    ctk.CTkLabel(master=ventana, text="⚖️", font=("Arial", 50), text_color="#4A311E").pack(pady=(30, 5))
    ctk.CTkLabel(master=ventana, text="SISTEMA INTEGRAL JURÍDICO", font=("Times New Roman", 20, "bold"), text_color="#1F1711").pack(pady=5)
    ctk.CTkLabel(master=ventana, text="Inicio de sesión unificado para personal autorizado", font=("Arial", 11), text_color="#7D5D42").pack(pady=(0, 25))

    # Campo ID Empleado
    ctk.CTkLabel(master=ventana, text="ID de Empleado", font=("Arial", 12), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
    txt_usuario = ctk.CTkEntry(master=ventana, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", border_width=1, height=35, corner_radius=6)
    txt_usuario.pack(fill="x", padx=40, pady=(0, 15))

    # Campo Contraseña
    ctk.CTkLabel(master=ventana, text="Contraseña", font=("Arial", 12), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
    txt_password = ctk.CTkEntry(master=ventana, show="*", fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", border_width=1, height=35, corner_radius=6)
    txt_password.pack(fill="x", padx=40, pady=(0, 30))

    # Botón de Ingreso
    btn_login = ctk.CTkButton(
        master=ventana, text="INICIAR SESIÓN", font=("Arial", 13, "bold"), fg_color="#4A311E", hover_color="#362315", text_color="#FFFFFF", height=40, corner_radius=6,
        command=lambda: validar_login(app_login, txt_usuario.get(), txt_password.get())
    )
    btn_login.pack(fill="x", padx=40, pady=(0, 40))

    ctk.CTkLabel(master=ventana, text="Bufete Jurídico & Asociados - Todos los derechos reservados.", font=("Arial", 10), text_color="#1F1711").pack(side="bottom", pady=20)

    app_login.mainloop()

if __name__ == "__main__":
    crear_login()

