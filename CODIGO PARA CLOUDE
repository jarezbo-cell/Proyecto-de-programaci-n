            ctk.CTkButton(
                t, text="Eliminar", fg_color="#C62828", width=90, command=eliminar
            ).pack(side="right", padx=12, pady=8)  # Coloca el botón rojo de eliminación al lado derecho de la tarjeta

    refrescar()  # Dibuja el listado inicial al entrar a la vista


