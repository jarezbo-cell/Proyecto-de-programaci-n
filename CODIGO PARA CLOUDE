# =============================================================================================
# LÓGICA COMPARTIDA DE LA BASE DE DATOS Y AYUDANTES DE INTERFAZ
# =============================================================================================
def ejecutar_sql(query, parametros=(), fetchone=False, fetchall=False, commit=False):
    # Función empaquetadora central para evitar duplicar código de conexiones SQL a lo largo del programa
    try:  # Abre un bloque de excepción para mitigar caídas imprevistas por bloqueos de base de datos
        conn = sqlite3.connect(RUTA_BD)  # Establece la conexión directa con el archivo de base de datos relacional
        cursor = conn.cursor()  # Instancia el cursor para poder transaccionar comandos SQL estructurados
        cursor.execute(query, parametros)  # Ejecuta la consulta inyectando los parámetros de manera limpia y segura
        res = None  # Define la variable de respuesta por defecto en un estado vacío
        if fetchone:  # Evalúa si la lógica superior requiere únicamente extraer una sola tupla de la consulta
            res = cursor.fetchone()  # Recupera el primer registro que coincida con los criterios de búsqueda
        if fetchall:  # Evalúa si la lógica superior requiere extraer el set completo de registros encontrados
            res = cursor.fetchall()  # Recupera todas las filas devueltas por la consulta estructurada
        if commit:  # Evalúa si se trata de una transacción de escritura (INSERT, UPDATE o DELETE)
            conn.commit()  # Asienta los cambios permanentemente en el almacenamiento físico del disco duro
        rowcount = cursor.rowcount  # Captura la cantidad total de filas que resultaron afectadas por la sentencia
        conn.close()  # Cierra la conexión de manera limpia para no saturar los accesos concurrentes al archivo
        return res if (fetchone or fetchall) else rowcount  # Retorna las tuplas de datos o el conteo de filas afectadas
    except sqlite3.Error as e:  # Atrapa fallos específicos de sintaxis o de conectividad propios del motor SQLite3
        messagebox.showerror(
            "Error SQL", str(e)
        )  # Despliega una alerta emergente notificando la causa exacta del error de base de datos
        return None  # Retorna un estado vacío para indicar que la ejecución no concluyó de forma exitosa


def verificar_estructura_bd():
    # Agrega de forma segura las columnas nuevas necesarias para rastrear quién redactó un recado
    # y quién subió un caso, sin afectar bases de datos que ya existan con la estructura antigua
    columnas_nuevas = [
        ("Recado", "IDU_REDACTOR", "TEXT"),
        ("Caso", "IDU_CREADOR", "TEXT"),
    ]
    try:  # Envuelve la verificación estructural en un bloque de excepción por seguridad
        conn = sqlite3.connect(RUTA_BD)  # Abre la conexión directa hacia el archivo físico de la base de datos
        cursor = conn.cursor()  # Instancia el cursor necesario para ejecutar sentencias DDL de estructura
        for tabla, columna, tipo in columnas_nuevas:  # Recorre cada columna que se necesita garantizar que exista
            try:  # Intenta agregar la columna asumiendo que aún no existe en la tabla
                cursor.execute(f"ALTER TABLE {tabla} ADD COLUMN {columna} {tipo}")  # Ejecuta el ALTER TABLE necesario
            except sqlite3.OperationalError:  # Se dispara si la columna ya fue agregada en una ejecución previa
                pass  # Ignora el error de "columna duplicada" porque significa que ya estaba lista
        conn.commit()  # Asienta cualquier cambio estructural aplicado sobre el archivo de base de datos
        conn.close()  # Cierra la conexión de manera ordenada tras la verificación
    except sqlite3.Error as e:  # Atrapa cualquier otro fallo de conectividad al intentar verificar la estructura
        messagebox.showerror("Error de Estructura", str(e))  # Notifica al usuario si la verificación no pudo completarse


