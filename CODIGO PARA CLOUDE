        elif texto == "VER NOMINA":  # Mapea la opción que permite inspeccionar la nómina personal calculada
            cmd = lambda: vista_pasante_ver_nomina(panel_vistas, session["idu"])  # Vincula la consulta de recibos pasando el IDU activo
        elif texto == "BUSCAR CASO":  # Mapea la opción que despliega el histórico de asesorías de la firma
