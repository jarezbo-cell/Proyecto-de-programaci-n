        ctk.CTkButton(
            sidebar,
            text=f"{icono}   {texto}",
            anchor="w",
            text_color="#EFE7DC",
            fg_color="#4E342E",
            hover_color="#5D4037",
            border_color="#6D4C41",
            border_width=1,
            height=32,
            corner_radius=8,
            font=("Arial", 10, "bold"),
            command=cmd,
        ).pack(fill="x", padx=10, pady=3)  # Instancia y empaqueta el botón reduciendo su alto y separación para que todos quepan visibles

    def logout():  # Función interna encargada de invalidar el tablero de control para regresar de forma segura al login
        root.destroy()  # Destruye por completo la ventana del tablero de control liberando los recursos gráficos
        crear_login_inicial()  # Invoca la rutina inicializadora para desplegar nuevamente el formulario de inicio de sesión

    # Botón de desconexión estático montado en la base del panel derecho (Totalmente inmune a las rutinas de limpieza de vistas)
    ctk.CTkButton(
        panel_derecho,
        text="● CERRAR SESIÓN",
