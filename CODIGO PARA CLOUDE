    limpiar_y_titular(panel, "✉️ MANDAR Y VER RECADOS")  # Limpia el lienzo y coloca el título de la vista combinada

    ctk.CTkLabel(
        panel, text="Código (IDR):", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Coloca la etiqueta del identificador del nuevo recado
    ent_idr = ctk.CTkEntry(panel, width=350, fg_color="#FFFFFF")  # Inicializa la entrada de texto para el IDR
    ent_idr.pack(anchor="w", padx=40, pady=5)  # Posiciona la entrada de texto en el formulario

    ctk.CTkLabel(
        panel, text="Mensaje:", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Coloca la etiqueta del cuerpo del mensaje
    txt_msg = ctk.CTkTextbox(
        panel, width=350, height=80, border_width=1, border_color="#C2BCB4"
    )  # Crea la caja multilínea para redactar el recado
    txt_msg.pack(anchor="w", padx=40, pady=5)  # Posiciona la caja de texto en el formulario

    scr = ctk.CTkScrollableFrame(
        panel, fg_color="#F9F8F6", border_color="#C2BCB4", border_width=1
    )  # Crea el contenedor scrolleable donde se listará el historial de recados

    def refrescar():  # Subfunción que dibuja o redibuja el historial completo de recados
        for w in scr.winfo_children():  # Recorre los widgets existentes en el contenedor
            w.destroy()  # Elimina cada tarjeta previa antes de redibujar
        recados = ejecutar_sql(
            "SELECT Recado.IDR, Recado.RECADO, Usuarios.NOMBRE FROM Recado "
            "LEFT JOIN Usuarios ON Recado.IDU_REDACTOR = Usuarios.IDU",
            fetchall=True,
        )  # Consulta todos los recados cruzándolos con el nombre de quien los redactó
        if not recados:  # Evalúa si no existe ningún recado registrado todavía
            ctk.CTkLabel(
                scr, text="No hay recados registrados.", font=("Arial", 12, "italic"), text_color="gray"
            ).pack(pady=10)  # Muestra el aviso informativo si no hay resultados
        for r in recados or []:  # Itera cada recado devuelto por la consulta
            t = ctk.CTkFrame(
                scr, fg_color="#FFFFFF", border_color="#EFE7DC", border_width=1, corner_radius=6
            )  # Diseña la tarjeta individual de cada recado
            t.pack(fill="x", pady=4, padx=5)  # Acopla la tarjeta expandiéndola horizontalmente
            autor = r[2] if r[2] else "Desconocido"  # Resuelve un nombre de respaldo si no se encontró coincidencia
            ctk.CTkLabel(
                t,
                text=f"Código IDR: {r[0]}\nMensaje: {r[1]}\nRedactado por: {autor}",
                font=("Arial", 11),
                text_color="#3E2723",
                justify="left",
            ).pack(side="left", pady=8, padx=12, anchor="w")  # Imprime el detalle completo del recado y de su autor

            def eliminar(idr=r[0]):  # Captura el IDR actual como valor por defecto para evitar el bug de closures
                if ejecutar_sql("DELETE FROM Recado WHERE IDR = ?", (idr,), commit=True) is not None:
                    messagebox.showinfo("Éxito", f"Recado {idr} eliminado.")  # Confirma la eliminación exitosa
                    refrescar()  # Redibuja la lista para reflejar la eliminación de inmediato

            ctk.CTkButton(
                t, text="Eliminar", fg_color="#C62828", width=90, command=eliminar
            ).pack(side="right", padx=12, pady=8)  # Coloca el botón rojo de eliminación al lado derecho de la tarjeta

    def guardar():  # Subfunción que procesa el envío de un nuevo recado desde la vista del jefe
        idr, msg = ent_idr.get().strip(), txt_msg.get("1.0", "end-1c").strip()  # Extrae y depura el texto de ambos campos
        if not idr or not msg:  # Valida que ninguno de los dos campos se encuentre vacío
            return messagebox.showwarning("Campos Vacíos", "Rellene el IDR y el Mensaje.")  # Frena el envío si faltan datos
        if (
            ejecutar_sql(
                "INSERT INTO Recado (RECADO, IDR, IDU_REDACTOR) VALUES (?, ?, ?)",
                (msg, idr, session["idu"]),
                commit=True,
            )
            is not None
        ):  # Inserta el recado guardando también el IDU del jefe que lo redactó
            messagebox.showinfo("Éxito", f"Recado {idr} registrado.")  # Notifica el registro exitoso del recado
            ent_idr.delete(0, "end")  # Limpia el campo del IDR para permitir un nuevo registro inmediato
            txt_msg.delete("1.0", "end")  # Limpia el área de texto del mensaje redactado
            refrescar()  # Redibuja el historial para reflejar el nuevo recado de inmediato

    ctk.CTkButton(
        panel, text="Enviar Recado", fg_color="#5D4037", command=guardar, width=200
    ).pack(anchor="w", padx=40, pady=10)  # Instancia el botón de envío del nuevo recado

    ctk.CTkLabel(
        panel, text="Historial de Recados:", font=("Arial", 13, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40, pady=(10, 0))  # Coloca el subtítulo que antecede al historial
    scr.pack(fill="both", expand=True, padx=40, pady=10)  # Expande el contenedor scrolleable del historial
    refrescar()  # Dibuja el historial inicial al entrar a la vista


def vista_jefe_pagar_nomina(panel, callback_inicio):
    # Proporciona la calculadora financiera para autorizar y asentar los sueldos en el histórico de nómina
    limpiar_y_titular(panel, "🪙 PAGAR NOMINA DE EMPLEADOS")  # Reinicia los paneles e introduce el título financiero de nómina

    ctk.CTkLabel(
        panel, text="IDU Colaborador:", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Pinta la etiqueta indicadora para capturar la clave del empleado a remunerar
    ent_idu = ctk.CTkEntry(panel, width=350, fg_color="#FFFFFF")  # Inicializa la caja para introducir el IDU del trabajador
    ent_idu.pack(anchor="w", padx=40, pady=5)  # Posiciona la caja de texto en la vista actual

    ctk.CTkLabel(
        panel, text="Salario Base ($):", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Pinta la etiqueta indicadora para ingresar el monto bruto percibido
    ent_sal = ctk.CTkEntry(panel, width=350, fg_color="#FFFFFF")  # Inicializa la entrada numérica en formato de cadena
    ent_sal.pack(anchor="w", padx=40, pady=5)  # Acopla el campo de salario respetando la alineación izquierda

    def pagar():  # Realiza las operaciones matemáticas de impuestos y asienta el registro contable definitivo
        idu, sal_str = ent_idu.get().strip(), ent_sal.get().strip()  # Extrae y remueve espacios en blanco de las cajas de texto
        if not idu or not sal_str:  # Controla de forma preventiva que las casillas contengan información para calcular
            return messagebox.showwarning("Atención", "Complete las casillas.")  # Detiene la operación contable

        emp = ejecutar_sql(
            "SELECT NOMBRE, ROL FROM Usuarios WHERE IDU = ?", (idu,), fetchone=True
        )  # Busca el nombre y el rol vigentes del colaborador directo en la tabla de usuarios
        if not emp:  # Verifica primero si el identificador no coincide con ningún empleado de la firma
            return messagebox.showerror("Error", "El IDU ingresado no existe.")  # Notifica el error de clave de usuario al jefe

        try:  # Envuelve la conversión numérica para evitar que un valor no numérico rompa el programa
            sal_base = float(sal_str)  # Convierte de forma explícita el texto salarial en un tipo de dato flotante numérico
        except ValueError:  # Se dispara si el texto ingresado no puede interpretarse como un número
            return messagebox.showerror("Error", "El Salario Base debe ser un número válido.")  # Informa el formato incorrecto

        isr = sal_base * 0.10  # Aplica la deducción matemática fija del diez por ciento por concepto de retención de ISR
        tot = sal_base - isr  # Deduce analíticamente el monto neto final restando la retención al salario bruto original
        if (
            ejecutar_sql(
                "INSERT INTO Nomina (IDU, NOMBRE, [SALARIO BASE], ISR, TOTAL, ROL) VALUES (?, ?, ?, ?, ?, ?)",
                (idu, emp[0], sal_base, isr, tot, emp[1]),
                commit=True,
            )
            is not None
        ):  # Inserta de manera estructurada el recibo de pago calculado en el histórico de nómina de la firma
            messagebox.showinfo("Éxito", f"Pago cargado para {emp[0]}.")  # Muestra aviso confirmando el depósito cargado
            callback_inicio()  # Cierra la calculadora de nómina redirigiendo al panel de inicio unificado

    ctk.CTkButton(
        panel, text="Autorizar y Pagar", fg_color="#5D4037", command=pagar, width=200
    ).pack(anchor="w", padx=40, pady=15)  # Instancia y posiciona el botón de autorización de pagos financieros


