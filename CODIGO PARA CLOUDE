def abrir_tablero(rol, titulo_tarjeta, botones, session):
    # Orquesta y despliega la ventana principal de comandos adaptando dinámicamente los accesos según el rol validado
    root = ctk.CTk()  # Inicializa la ventana principal que servirá de raíz estructural para el panel de control
