# ACCESO DE CREDENCIALES AL SISTEMA (LOGIN ORIGINAL)
# =============================================================================================
def realizar_login_sql(win, user, pwd):
    # Gestiona y valida las credenciales introducidas contrastándolas de forma segura con los registros de la base de datos
    u, p = user.strip(), pwd.strip()  # Extrae el texto ingresado removiendo espacios vacíos de los extremos
    if not u or not p:  # Evalúa preventivamente si el usuario omitió rellenar alguna de las dos casillas obligatorias
        return messagebox.showwarning("Advertencia", "Por favor llene las casillas.")  # Detiene la validación lanzando aviso

    res = ejecutar_sql(
        "SELECT IDU, NOMBRE, CONTRASEÑA, ROL FROM Usuarios WHERE LOWER(TRIM(IDU)) = LOWER(?) AND LOWER(TRIM(CONTRASEÑA)) = LOWER(?)",
        (u, p),
        fetchone=True,
    )  # Ejecuta una búsqueda depurando variaciones de mayúsculas/minúsculas y espacios en blanco con LOWER y TRIM
    if res:  # Evalúa si la base de datos localizó un registro coincidente con las credenciales provistas
        idu_bd, nombre_bd, _, rol_bd = res  # Desempaqueta las propiedades devueltas de la fila de datos
        sesion = {"idu": idu_bd, "nombre": str(nombre_bd).upper()}  # Inicializa el diccionario maestro de sesión con datos en mayúsculas
        rol_limpio = str(rol_bd).upper().strip()  # Estandariza la cadena del rol removiendo espacios y forzando mayúsculas

        win.destroy()  # Destruye la ventana del formulario de login al haber validado las credenciales con éxito

        if "JEFE" in rol_limpio:  # Rutea condicionalmente al tablero del rol administrativo jefe
            abrir_tablero("JEFE", "INFORMACIÓN DEL JEFE", BOTONES_JEFE, sesion)  # Lanza el tablero inyectando controles de jefe
        elif "SUPERUSUARIO" in rol_limpio:  # Rutea condicionalmente al tablero del rol administrativo jefe
            abrir_tablero("SUPERUSUARIO", "INFORMACIÓN DEL JEFE", BOTONES_JEFE, sesion)  # Lanza el tablero inyectando controles de jefe
        elif "PASANTE" in rol_limpio:  # Rutea condicionalmente al tablero diseñado para el cuerpo de pasantes de la firma
            abrir_tablero(
                "PASANTE", "INFORMACIÓN DEL PASANTE", BOTONES_PASANTE, sesion
            )  # Lanza el tablero con los accesos operativos del pasante
        elif "ABOGADO" in rol_limpio:  # Rutea condicionalmente al tablero con las herramientas especializadas para abogados
            abrir_tablero("ABOGADO", "INFORMACIÓN DEL ABOGADO", BOTONES_ABOGADO, sesion)  # Despliega el panel de control del abogado
        else:  # Caso de escape por si el rol existe en la base de datos pero no cuenta con un ruteo asignado en el código
            messagebox.showerror("Error", f"Rol '{rol_limpio}' sin vista asignada.")  # Alerta sobre la falta de configuración del rol
            crear_login_inicial()  # Lanza nuevamente el inicio de sesión unificado
    else:  # Bloque ejecutado cuando las credenciales no coinciden con ningún registro de la tabla de usuarios
        messagebox.showerror("Error", "ID de Empleado o Contraseña incorrectos.")  # Muestra aviso de denegación de acceso


def crear_login_inicial():
    # Estructura y despliega el formulario unificado de inicio de sesión del sistema jurídico
    win = ctk.CTk()  # Crea la ventana raíz que alojará los componentes gráficos del control de acceso
    win.title("Sistema Jurídico - Inicio de Sesión")  # Establece el título formal de la ventana de login
    win.geometry("450x550")  # Asigna una resolución cuadrada y compacta idónea para un formulario de acceso
    win.resizable(False, False)  # Restringe el redimensionamiento de la ventana para preservar la composición visual fija
    ctk.set_appearance_mode("light")  # Forzar el modo claro para asegurar la fidelidad cromática de los componentes de diseño
    win.configure(fg_color="#FFE7DC")  # Aplica el tono beige claro de fondo en toda la superficie de la ventana externa

    card = ctk.CTkFrame(
        win, fg_color="#F9F8F6", corner_radius=15, border_color="#C2BCB4", border_width=1
    )  # Diseña una tarjeta central blanca para encapsular los campos del formulario de manera limpia
    card.pack(pady=30, padx=30, fill="both", expand=True)  # Ajusta la tarjeta central centrándola con márgenes uniformes

    ctk.CTkLabel(card, text="⚖️", font=("Arial", 50), text_color="#4A311E").pack(pady=(30, 5))  # Pinta el logotipo de balanza superior
    ctk.CTkLabel(
        card,
        text="SISTEMA INTEGRAL JURÍDICO",
        font=("Times New Roman", 20, "bold"),
        text_color="#1F1711",
    ).pack(pady=2)  # Pinta el título de marca de la aplicación jurídica
    ctk.CTkLabel(
        card,
        text="Inicio de sesión unificado para personal autorizado",
        font=("Arial", 11),
        text_color="#7D5D42",
    ).pack(pady=(0, 25))  # Pinta la leyenda informativa de seguridad de la firma

    ctk.CTkLabel(
        card,
        text="Correo Electrónico / ID de Empleado",
        font=("Arial", 11),
        text_color="#1F1711",
    ).pack(anchor="w", padx=40)  # Pinta la etiqueta del campo de identificación del usuario
    ent_user = ctk.CTkEntry(
        card,
        placeholder_text="Escriba su identificador...",
        width=320,
        fg_color="#FFFFFF",
        text_color="#1F1711",
        border_color="#C2BCB4",
    )  # Configura el control de entrada de texto para recolectar el ID del empleado
    ent_user.pack(pady=(0, 15))  # Posiciona la caja de texto aplicando una holgura inferior

    ctk.CTkLabel(card, text="Contraseña", font=("Arial", 11), text_color="#1F1711").pack(anchor="w", padx=40)  # Pinta la etiqueta del campo de la contraseña secreta
    ent_pwd = ctk.CTkEntry(
        card,
        placeholder_text="••••••••",
        show="*",
        width=320,
        fg_color="#FFFFFF",
        text_color="#1F1711",
        border_color="#C2BCB4",
    )  # Configura la caja ocultando los caracteres visibles mediante viñetas circulares por privacidad
    ent_pwd.pack(pady=(0, 25))  # Posiciona la entrada de contraseña en la tarjeta del formulario

    ctk.CTkButton(
        card,
        text="INICIAR SESIÓN",
        fg_color="#4A311E",
        hover_color="#5A3E29",
        text_color="#FFFFFF",
        font=("Arial", 12, "bold"),
        height=42,
        width=320,
        command=lambda: realizar_login_sql(win, ent_user.get(), ent_pwd.get()),
    ).pack(pady=10)  # Crea el botón de envío enlazando la lógica de validación mediante una función anónima lambda

    ctk.CTkLabel(
        card,
        text="Bufete Jurídico & Asociados - Todos los derechos reservados.",
        font=("Arial", 9),
        text_color="#7D5D42",
    ).pack(side="bottom", pady=15)  # Inserta la nota legal de propiedad intelectual al pie del formulario blanco

    win.mainloop()  # Inicia el bucle de escucha de la ventana del login manteniendo la interfaz responsiva


if __name__ == "__main__":
    verificar_estructura_bd()  # Verifica y actualiza la estructura de la base de datos antes de arrancar la aplicación
    crear_login_inicial()  # Ejecuta el programa llamando al login inicializador como punto de entrada de la aplicación
