def vista_pasante_redactar_recado(panel, callback_inicio, session):
    # Genera el formulario interactivo para que el personal redacte un mensaje asociado a un ID único
    limpiar_y_titular(panel, "✍️ REDACTAR NUEVO RECADO")  # Limpia la interfaz y renderiza el título superior elegante

    ctk.CTkLabel(
        panel, text="Código (IDR):", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Pinta la etiqueta informativa del identificador del recado
    ent_idr = ctk.CTkEntry(
        panel, width=350, fg_color="#FFFFFF"
    )  # Inicializa el campo de entrada de texto plano para capturar el IDR
    ent_idr.pack(anchor="w", padx=40, pady=5)  # Acopla el campo de entrada en el contenedor principal con espaciado

    ctk.CTkLabel(
        panel, text="Mensaje:", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Pinta la etiqueta indicadora para el cuerpo del mensaje
    txt_msg = ctk.CTkTextbox(
        panel, width=350, height=120, border_width=1, border_color="#C2BCB4"
    )  # Crea una caja de texto multilínea ideal para descripciones amplias o recados largos
    txt_msg.pack(anchor="w", padx=40, pady=5)  # Acopla la caja multilínea aplicando bordes definidos de color arena

    def guardar():  # Subfunción interna disparada por el botón para procesar el almacenamiento del recado
        idr, msg = ent_idr.get().strip(), txt_msg.get("1.0", "end-1c").strip()  # Extrae los textos removiendo espacios vacíos
        if not idr or not msg:  # Valida condicionalmente si alguno de los dos campos lógicos se encuentra vacío
            return messagebox.showwarning(
                "Campos Vacíos", "Rellene el IDR y el Mensaje."
            )  # Lanza aviso y frena la ejecución
        if (
            ejecutar_sql(
                "INSERT INTO Recado (RECADO, IDR, IDU_REDACTOR) VALUES (?, ?, ?)",
                (msg, idr, session["idu"]),
                commit=True,
            )
            is not None
        ):  # Ejecuta la inserción del recado en la tabla correspondiente, guardando también quién lo redactó
            messagebox.showinfo(
                "Éxito", f"Recado {idr} registrado."
            )  # Muestra confirmación de éxito al usuario
            callback_inicio()  # Invoca la rutina de retorno para enviar al usuario de vuelta a la pantalla de bienvenida

    ctk.CTkButton(
        panel, text="Guardar Recado", fg_color="#5D4037", command=guardar, width=200
    ).pack(anchor="w", padx=40, pady=15)  # Crea y empaqueta el botón de guardado con el color café corporativo


def vista_ver_recados(panel, permitir_eliminar=False):
    # Vista compartida entre Pasante, Abogado y Jefe: despliega los recados junto con el nombre de quien los redactó
    titulo = "🗑️ VER Y ELIMINAR RECADOS" if permitir_eliminar else "👀 VER RECADOS"  # Ajusta el título según el permiso
    limpiar_y_titular(panel, titulo)  # Limpia la interfaz y coloca el encabezado correspondiente
    scr = ctk.CTkScrollableFrame(
        panel, fg_color="#F9F8F6", border_color="#C2BCB4", border_width=1
    )  # Crea un marco con scroll bar automático ideal para albergar listados extensos
    scr.pack(fill="both", expand=True, padx=40, pady=10)  # Ajusta el contenedor scrolleable para expandirse en toda la pantalla

    def refrescar():  # Subfunción interna que dibuja (o redibuja) el listado completo de recados
        for w in scr.winfo_children():  # Itera sobre los elementos existentes en el contenedor scrolleable
            w.destroy()  # Destruye cada tarjeta previa para evitar duplicados al refrescar
        recados = ejecutar_sql(
            "SELECT Recado.IDR, Recado.RECADO, Usuarios.NOMBRE FROM Recado "
            "LEFT JOIN Usuarios ON Recado.IDU_REDACTOR = Usuarios.IDU",
            fetchall=True,
        )  # Cruza el recado con la tabla de usuarios para obtener el nombre real de quien lo redactó
        if not recados:  # Evalúa si la consulta no arrojó ningún recado registrado
            ctk.CTkLabel(
                scr, text="No hay recados registrados.", font=("Arial", 12, "italic"), text_color="gray"
            ).pack(pady=20)  # Muestra un aviso en cursiva indicando que no hay información
        for r in recados or []:  # Itera cada recado devuelto por la consulta
            t = ctk.CTkFrame(
                scr, fg_color="#FFFFFF", border_color="#EFE7DC", border_width=1, corner_radius=6
            )  # Diseña una tarjeta blanca individual para presentar el recado
            t.pack(fill="x", pady=4, padx=5)  # Acopla la tarjeta expandiéndola horizontalmente
            autor = r[2] if r[2] else "Desconocido"  # Resuelve un nombre de respaldo si no se encontró coincidencia
            ctk.CTkLabel(
                t,
                text=f"Código IDR: {r[0]}\nMensaje: {r[1]}\nRedactado por: {autor}",
                font=("Arial", 11),
                text_color="#3E2723",
                justify="left",
            ).pack(side="left", pady=8, padx=12, anchor="w")  # Imprime el detalle completo del recado y su autor

            if permitir_eliminar:  # Solo el Jefe recibe la capacidad de eliminar recados desde esta vista
                def eliminar(idr=r[0]):  # Captura el IDR actual como valor por defecto para evitar el bug de closures
                    if ejecutar_sql("DELETE FROM Recado WHERE IDR = ?", (idr,), commit=True) is not None:
                        messagebox.showinfo("Éxito", f"Recado {idr} eliminado.")  # Confirma la eliminación exitosa
                        refrescar()  # Redibuja la lista para reflejar la eliminación de inmediato

                ctk.CTkButton(
                    t, text="Eliminar", fg_color="#C62828", width=90, command=eliminar
                ).pack(side="right", padx=12, pady=8)  # Coloca el botón rojo de eliminación al lado derecho de la tarjeta

    refrescar()  # Dibuja el listado inicial al entrar a la vista


def vista_pasante_subir_caso(panel, callback_inicio, session):
    # Construye el formulario técnico requerido para indexar nuevos expedientes legales al sistema unificado
    limpiar_y_titular(panel, "🔼 SUBIR NUEVO CASO AL SISTEMA")  # Prepara la región gráfica e inserta el título descriptivo

    ctk.CTkLabel(
        panel, text="Código (IDC):", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Genera la etiqueta visual para el campo del identificador de caso
    ent_idc = ctk.CTkEntry(
        panel, width=350, fg_color="#FFFFFF"
    )  # Define la entrada de texto de fondo blanco para recolectar el IDC
    ent_idc.pack(anchor="w", padx=40, pady=5)  # Posiciona la entrada de texto plano bajo los parámetros de diseño

    ctk.CTkLabel(
        panel, text="Descripción:", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Genera la etiqueta visual correspondiente a los detalles del litigio
    ent_cas = ctk.CTkEntry(
        panel, width=350, fg_color="#FFFFFF"
    )  # Define la caja de entrada para recolectar la descripción resumida del asunto
    ent_cas.pack(anchor="w", padx=40, pady=5)  # Acopla el control gráfico respetando la alineación a la izquierda

    def guardar():  # Función interna para validar y escribir los datos del nuevo expediente en la base de datos
        idc, cas = ent_idc.get().strip(), ent_cas.get().strip()  # Obtiene el texto depurado de ambas cajas de entrada
        if not idc or not cas:  # Verifica de forma estricta si el usuario omitió capturar algún dato requerido
            return messagebox.showwarning(
                "Campos Incompletos", "Ingrese IDC y Descripción."
            )  # Despliega advertencia de seguridad
        if (
            ejecutar_sql(
                "INSERT INTO Caso (IDC, CASO, ID_ABOGADO, IDU_CREADOR) VALUES (?, ?, NULL, ?)",
                (idc, cas, session["idu"]),
                commit=True,
            )
            is not None
        ):  # Almacena el caso vinculando por defecto el abogado como nulo y guardando quién lo subió
            ejecutar_sql(
                "INSERT INTO Aseroria (IDC, CASO, FECHA) VALUES (?, ?, ?)",
                (idc, cas, datetime.now().strftime("%d/%m/%Y")),
                commit=True,
            )  # Registra en paralelo el historial de asesoría estampando la fecha actual en formato regional
            messagebox.showinfo("Éxito", f"Caso {idc} guardado en el sistema.")  # Notifica que los datos fueron guardados
            callback_inicio()  # Lanza el retorno al menú principal limpiando el panel dinámico

    ctk.CTkButton(
        panel, text="Subir Caso", fg_color="#5D4037", command=guardar, width=200
    ).pack(anchor="w", padx=40, pady=15)  # Crea el botón de acción principal de inserción de expedientes


