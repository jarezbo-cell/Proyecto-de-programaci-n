        elif texto == "VER CASOS ASIGNADOS":  # Mapea el listado de casos que ya tienen abogado asignado
            cmd = lambda: vista_jefe_ver_casos_asignados(panel_vistas)  # Vincula la vista de casos ya asignados
        elif texto == "VER CASOS":  # Mapea el listado general de casos junto con su creador y abogado, con opción de eliminarlos
            cmd = lambda: vista_jefe_ver_casos(panel_vistas)  # Vincula la vista completa de casos registrados
        elif texto == "MANDAR Y VER RECADO":  # Mapea la vista combinada de envío, consulta y eliminación de recados del jefe
            cmd = lambda: vista_jefe_mandar_ver_recado(panel_vistas, show_home, session)  # Vincula la vista combinada pasando la sesión activa
        elif texto == "PAGAR NOMINA":  # Mapea las facultades contables del jefe para procesar sueldos
