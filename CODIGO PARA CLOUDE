        info,
        text="👤",
        font=("Arial", 24),
        fg_color="#EFE7DC",
        text_color="#3E2723",
        width=40,
        height=40,
        corner_radius=20,
    ).pack(pady=(0, 10))  # Icono circular simulando el avatar del usuario autenticado

