def vista_jefe_ver_casos(panel):
    # Muestra la totalidad de los casos registrados, incluyendo quién los subió, a qué abogado le corresponden, y permite eliminarlos
    limpiar_y_titular(panel, "🗂️ VER CASOS REGISTRADOS")  # Limpia el lienzo y coloca el título general del listado
    scr = ctk.CTkScrollableFrame(
        panel, fg_color="#F9F8F6", border_color="#C2BCB4", border_width=1
    )  # Crea el contenedor scrolleable que alojará todas las tarjetas de casos
    scr.pack(fill="both", expand=True, padx=40, pady=10)  # Expande el contenedor en el espacio disponible

    def refrescar():  # Subfunción que dibuja o redibuja el listado completo de casos
        for w in scr.winfo_children():  # Recorre los widgets existentes en el contenedor
            w.destroy()  # Elimina cada tarjeta previa para evitar duplicados al refrescar
        regs = ejecutar_sql(
            "SELECT Caso.IDC, Caso.CASO, u_creador.NOMBRE, u_abogado.NOMBRE FROM Caso "
            "LEFT JOIN Usuarios u_creador ON Caso.IDU_CREADOR = u_creador.IDU "
            "LEFT JOIN Usuarios u_abogado ON Caso.ID_ABOGADO = u_abogado.IDU",
            fetchall=True,
        )  # Cruza dos veces la tabla de usuarios: una para el creador del caso y otra para el abogado asignado
        if not regs:  # Evalúa si la consulta no arrojó ningún caso registrado
            ctk.CTkLabel(
                scr, text="No hay casos registrados.", font=("Arial", 12, "italic"), text_color="gray"
            ).pack(pady=20)  # Muestra el aviso informativo si la tabla está vacía
        for r in regs or []:  # Itera cada caso devuelto por la consulta
            t = ctk.CTkFrame(
                scr, fg_color="#FFFFFF", border_color="#EFE7DC", border_width=1, corner_radius=8
            )  # Diseña la tarjeta individual del caso
            t.pack(fill="x", pady=5, padx=10)  # Acopla la tarjeta expandiéndola horizontalmente
            creador = r[2] if r[2] else "Desconocido"  # Resuelve un nombre de respaldo si el caso es anterior a este cambio
            abogado = r[3] if r[3] else "Sin asignar"  # Resuelve el texto a mostrar si aún no se asignó abogado
            ctk.CTkLabel(
                t,
                text=f"• IDC: {r[0]}\n• Descripción: {r[1]}\n• Subido por: {creador}\n• Abogado asignado: {abogado}",
                justify="left",
                font=("Arial", 11),
                text_color="#3E2723",
            ).pack(side="left", pady=10, padx=15, anchor="w")  # Imprime los detalles completos del caso dentro de la tarjeta

            def eliminar(idc=r[0]):  # Captura el IDC actual como valor por defecto para evitar el bug de closures
                if ejecutar_sql("DELETE FROM Caso WHERE IDC = ?", (idc,), commit=True) is not None:
                    ejecutar_sql("DELETE FROM Aseroria WHERE IDC = ?", (idc,), commit=True)  # Limpia también su historial asociado
                    messagebox.showinfo("Éxito", f"Caso {idc} eliminado.")  # Confirma la eliminación exitosa
                    refrescar()  # Redibuja la lista para reflejar la eliminación de inmediato

            ctk.CTkButton(
                t, text="Eliminar", fg_color="#C62828", width=90, command=eliminar
