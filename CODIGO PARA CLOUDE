    scr.pack(fill="both", expand=True, padx=40, pady=10)  # Empaqueta el marco expandiéndolo para aprovechar todo el espacio

    def refrescar():  # Subfunción que dibuja o redibuja el listado completo de asesorías
        for w in scr.winfo_children():  # Recorre los widgets existentes en el contenedor
            w.destroy()  # Elimina cada tarjeta previa para evitar duplicados al refrescar
        datos = ejecutar_sql(
            "SELECT rowid, IDC, CASO, FECHA FROM Aseroria", fetchall=True
        )  # Ejecuta la consulta de lectura de asesorías incluyendo el rowid único de cada renglón
        if not datos:  # Evalúa si no existe ninguna asesoría registrada todavía
            ctk.CTkLabel(
