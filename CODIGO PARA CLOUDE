    ctk.CTkLabel(sidebar, text="⚖️", font=("Arial", 32), text_color="#EFE7DC").pack(pady=(10, 2))  # Logotipo de balanza de la firma
    ctk.CTkLabel(
        sidebar,
        text="BUFETE JURÍDICO & ASOCIADOS",
        font=("Arial", 10, "bold"),
        text_color="#EFE7DC",
    ).pack(pady=(0, 15))  # Rótulo con el nombre comercial de la corporación jurídica
