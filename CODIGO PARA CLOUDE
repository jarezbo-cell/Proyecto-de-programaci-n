def abrir_editor_usuario(panel, callback_inicio, idu, nombre_actual, rol_actual):
    # Genera el formulario para actualizar la información (nombre, contraseña y rol) de un usuario ya existente
    limpiar_y_titular(panel, f"✏️ EDITAR USUARIO: {idu}")  # Limpia el lienzo y coloca el encabezado con el IDU en edición

    ctk.CTkLabel(
        panel, text="Nombre Completo:", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Coloca la etiqueta descriptiva del nombre
    ent_nom = ctk.CTkEntry(panel, width=350, fg_color="#FFFFFF")  # Inicializa la entrada de texto para el nombre
    ent_nom.insert(0, nombre_actual)  # Precarga el campo con el nombre actual del usuario
    ent_nom.pack(anchor="w", padx=40, pady=5)  # Posiciona la entrada de texto en el formulario

    ctk.CTkLabel(
        panel,
        text="Nueva Contraseña (dejar vacío para no cambiarla):",
        font=("Arial", 11, "bold"),
        text_color="#3E2723",
    ).pack(anchor="w", padx=40)  # Aclara que el campo de contraseña es opcional en la edición
    ent_pwd = ctk.CTkEntry(panel, width=350, fg_color="#FFFFFF", show="*")  # Inicializa la entrada enmascarada de contraseña
    ent_pwd.pack(anchor="w", padx=40, pady=5)  # Posiciona la entrada de contraseña en el formulario

    ctk.CTkLabel(
        panel, text="Rol / Puesto:", font=("Arial", 11, "bold"), text_color="#3E2723"
    ).pack(anchor="w", padx=40)  # Coloca la etiqueta del selector de rol
    combo_rol = ctk.CTkComboBox(panel, values=["PASANTE", "ABOGADO", "JEFE", "SUPERUSUARIO"], width=350)  # Instancia el combo de roles
    combo_rol.set(rol_actual)  # Preselecciona el rol actual del usuario en el combo
    combo_rol.pack(anchor="w", padx=40, pady=10)  # Posiciona el combo de selección en el formulario

    def actualizar():  # Subfunción que ejecuta el UPDATE con los nuevos valores capturados
        nom, pwd, rol = ent_nom.get().strip(), ent_pwd.get().strip(), combo_rol.get()  # Extrae los valores actuales del formulario
        if not nom:  # Verifica que el nombre no haya quedado vacío
            return messagebox.showwarning("Campos Vacíos", "El nombre no puede quedar vacío.")  # Frena la actualización
        if pwd:  # Evalúa si el jefe decidió también cambiar la contraseña del usuario
            filas = ejecutar_sql(
                "UPDATE Usuarios SET NOMBRE = ?, CONTRASEÑA = ?, ROL = ? WHERE IDU = ?",
                (nom.upper(), pwd, rol, idu),
                commit=True,
            )  # Actualiza nombre, contraseña y rol en un mismo movimiento
        else:  # Bloque ejecutado cuando el campo de contraseña se dejó vacío intencionalmente
            filas = ejecutar_sql(
                "UPDATE Usuarios SET NOMBRE = ?, ROL = ? WHERE IDU = ?",
                (nom.upper(), rol, idu),
                commit=True,
            )  # Actualiza únicamente el nombre y el rol, preservando la contraseña original
        if filas is not None:  # Evalúa si la sentencia UPDATE se ejecutó sin errores
            messagebox.showinfo("Éxito", f"Usuario {idu} actualizado.")  # Notifica al jefe la actualización exitosa
            vista_jefe_ver_usuarios(panel, callback_inicio)  # Regresa al listado ya refrescado con los datos nuevos

    ctk.CTkButton(
        panel, text="Guardar Cambios", fg_color="#2E7D32", command=actualizar, width=200
    ).pack(anchor="w", padx=40, pady=15)  # Instancia el botón de confirmación de los cambios
    ctk.CTkButton(
        panel,
        text="Cancelar",
        fg_color="#8D6E63",
        command=lambda: vista_jefe_ver_usuarios(panel, callback_inicio),
        width=200,
    ).pack(anchor="w", padx=40, pady=5)  # Instancia el botón para regresar sin aplicar cambios


