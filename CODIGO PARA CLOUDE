            ).pack(pady=20)  # Muestra el aviso informativo si no hay resultados
        for f in datos or []:  # Cicla de forma segura cada renglón recuperado del histórico de registros de asesorías
            t = ctk.CTkFrame(
                scr,
                fg_color="#FFFFFF",
                border_color="#EFE7DC",
