    root.geometry("1100x650")  # Define una resolución de pantalla base optimizada para paneles complejos
    ctk.set_appearance_mode("light")  # Configura la paleta visual de apariencia en modalidad clara de forma explícita
    root.configure(fg_color="#FFE7DC")  # Aplica el color beige claro perimetral exterior para mantener la identidad del software

    base = ctk.CTkFrame(root, fg_color="#3E2723", corner_radius=15)  # Define un marco central oscuro que unifica el espacio interior
