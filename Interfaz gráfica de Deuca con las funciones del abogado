                        conexion.close()
                        return
                    
                    cursor.execute(
                        "UPDATE Usuarios SET NOMBRE = ?, CONTRASENA = ?, ROL = ? WHERE LOWER(TRIM(IDU)) = LOWER(?)",
                        (nombre, contra, rol_elegido, idu)
                    )
                    messagebox.showinfo("Éxito", f"¡Datos de '{nombre}' actualizados correctamente!")
                else:
                    # SI NO EXISTE: Hacemos el alta normal (INSERT)
                    cursor.execute(
                        "INSERT INTO Usuarios (IDU, NOMBRE, CONTRASENA, ROL) VALUES (?, ?, ?, ?)",
                        (idu, nombre, contra, rol_elegido)
                    )
                    messagebox.showinfo("Éxito", f"¡Usuario '{nombre}' registrado exitosamente!")
                
