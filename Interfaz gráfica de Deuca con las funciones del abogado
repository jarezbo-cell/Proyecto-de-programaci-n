                return

            try:
                conexion = sqlite3.connect(RUTA_BD)
                cursor = conexion.cursor()
                
                cursor.execute("SELECT NOMBRE FROM Usuarios WHERE LOWER(TRIM(IDU)) = LOWER(?)", (idu,))
