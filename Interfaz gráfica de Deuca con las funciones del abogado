                resultado = cur.fetchone()  # Extrae la primera coincidencia
                conn.close()

                txt_resultado_ase_view.delete("1.0", "end")  # Limpia la caja de texto antes de insertar nuevos datos
                if resultado:
                    # Escribe los datos formateados con la información obtenida
                    txt_resultado_ase_view.insert("1.0", f"Fecha de Registro: {resultado[1]}\n\nDetalles del Caso:\n{resultado[0]}")
                else:
                    txt_resultado_ase_view.insert("1.0", "No se encontró ninguna asesoría con ese ID en el sistema.")
            except Exception as e:
                messagebox.showerror("Error", f"Fallo al buscar la asesoría:\n{e}")

        def db_cargar_recados():
            """Consulta todos los IDs de recados existentes en la base de datos real y los inserta en el ComboBox"""
            try:
                conn = sqlite3.connect(RUTA_BD)
                cur = conn.cursor()
                cur.execute("SELECT IDR FROM Recado")  # Trae toda la columna de identificadores reales de la tabla Recado[cite: 3]
                ids = [str(r[0]) for r in cur.fetchall()]  # Convierte las tuplas SQL en una lista normal de Python
                conn.close()
                
                if ids:
                    cmb_recados.configure(values=ids)  # Asigna los IDs encontrados al ComboBox dinámicamente
                    cmb_recados.set(ids[0])  # Muestra el primer ID por defecto
                    db_leer_recado(ids[0])  # Fuerza la lectura inicial del primer recado encontrado
                else:
                    cmb_recados.configure(values=["Sin recados"])
                    cmb_recados.set("Sin recados")
            except Exception as e:
                cmb_recados.configure(values=["Error de BD"])
                cmb_recados.set("Error de BD")

        def db_leer_recado(idr_seleccionado):
            """Se ejecuta automáticamente al seleccionar un recado distinto en el menú desplegable"""
            if idr_seleccionado in ("Sin recados", "Error de BD"): return  # Si la lista está vacía o falló, no hace nada
            try:
                conn = sqlite3.connect(RUTA_BD)
                cur = conn.cursor()
                cur.execute("SELECT RECADO FROM Recado WHERE IDR = ?", (idr_seleccionado,))  # Consulta los recados reales de la BD[cite: 3]
                resultado = cur.fetchone()
                conn.close()

                txt_contenido_recado.delete("1.0", "end")  # Borra el recado anterior de la pantalla
                if resultado:
                    txt_contenido_recado.insert("1.0", resultado[0])  # Muestra el nuevo mensaje real
            except Exception as e:
                messagebox.showerror("Error", f"Fallo al leer recado:\n{e}")

        def db_guardar_asesoria():
            """Toma los datos de los Entry y el Textbox para insertarlos en la tabla 'Aseroria'"""
            idc = txt_id_ase.get().strip()
            fecha = txt_fecha_ase.get().strip()
            detalles = txt_desc_ase.get("1.0", "end-1c").strip()  # Lee todo el cuadro de texto grande

            if not idc or not fecha or not detalles:  # Validación anti-vacíos
                messagebox.showwarning("Aviso", "Llene todos los campos de la asesoría.")
                return
            try:
                conn = sqlite3.connect(RUTA_BD)
                cur = conn.cursor()
                cur.execute("INSERT INTO Aseroria (IDC, CASO, FECHA) VALUES (?, ?, ?)", (idc, detalles, fecha))  # Guarda datos en Aseroria[cite: 3]
                conn.commit()  # Confirma y guarda el cambio permanente en SQLite
                conn.close()
                messagebox.showinfo("Éxito", "Asesoría registrada correctamente.")
                
                # Limpia los campos gráficos para que queden listos para un nuevo registro
                txt_id_ase.delete(0, 'end')
                txt_fecha_ase.delete(0, 'end')
                txt_desc_ase.delete("1.0", 'end')
            except Exception as e:
                messagebox.showerror("Error", f"Verifique que el ID del Caso exista en la tabla 'Caso'.\nDetalle: {e}")

        def db_agendar_audiencia():
            """Toma los datos de la interfaz de Audiencia y crea la tabla si esta no existía"""
            idc = txt_id_aud.get().strip()
            fecha = txt_fecha_aud.get().strip()
            juzgado = txt_juzgado.get().strip()

            if not idc or not fecha or not juzgado:
                messagebox.showwarning("Aviso", "Llene todos los campos de la audiencia.")
                return
            try:
                conn = sqlite3.connect(RUTA_BD)
                cur = conn.cursor()
                # Sentencia preventiva: crea la estructura de la tabla si el archivo .db no la tenía originalmente
                cur.execute("""
                    CREATE TABLE IF NOT EXISTS Audiencia (
                        ID_AUD INTEGER PRIMARY KEY AUTOINCREMENT,
                        IDC TEXT,
                        FECHA TEXT,
                        JUZGADO TEXT,
                        FOREIGN KEY(IDC) REFERENCES Caso(IDC)
                    )
                """)
                # Inserción de los datos tecleados por el abogado
                cur.execute("INSERT INTO Audiencia (IDC, FECHA, JUZGADO) VALUES (?, ?, ?)", (idc, fecha, juzgado))
                conn.commit()
                conn.close()
                messagebox.showinfo("Éxito", "Audiencia agendada correctamente.")
                
                # Limpieza de las cajas de texto tras guardar
                txt_id_aud.delete(0, 'end')
                txt_fecha_aud.delete(0, 'end')
                txt_juzgado.delete(0, 'end')
            except Exception as e:
                messagebox.showerror("Error", f"Error al agendar audiencia:\n{e}")

        # --- CONSTRUCCIÓN VISUAL: VISTA CONSULTAR ASESORÍA (Antes Ver Expediente) ---
        ctk.CTkLabel(master=vista_ver_asesoria, text="PANEL PRINCIPAL - CONSULTAR ASESORÍAS", font=("Times New Roman", 22, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(30, 10))
        ctk.CTkLabel(master=vista_ver_asesoria, text="ID de la Asesoría Guardada (IDC):", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
        
        # Sub-contenedor transparente para alinear el Entry de texto y el Botón de búsqueda de manera horizontal
        frame_buscar_ase = ctk.CTkFrame(master=vista_ver_asesoria, fg_color="transparent")
        frame_buscar_ase.pack(fill="x", padx=40, pady=(0, 10))
        
        txt_buscar_ase = ctk.CTkEntry(master=frame_buscar_ase, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=250, placeholder_text="Ej. A-123")
        txt_buscar_ase.pack(side="left", padx=(0, 10))
        
        # Botón que ejecuta la función db_buscar_asesoria al hacerle clic
        ctk.CTkButton(master=frame_buscar_ase, text="🔍 Buscar", fg_color="#4E342E", hover_color="#5D4037", width=100, command=db_buscar_asesoria).pack(side="left")
        
        ctk.CTkLabel(master=vista_ver_asesoria, text="Historial y Detalles de la Asesoría:", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
        txt_resultado_ase_view = ctk.CTkTextbox(master=vista_ver_asesoria, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", border_width=1, height=150)
        txt_resultado_ase_view.pack(fill="x", padx=40, pady=(0, 10))

        # --- CONSTRUCCIÓN VISUAL: VISTA RECADOS REALES ---
        ctk.CTkLabel(master=vista_recados, text="PANEL PRINCIPAL - RECADOS DEL SISTEMA", font=("Times New Roman", 22, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(30, 10))
        ctk.CTkLabel(master=vista_recados, text="Seleccionar Recado Registrado (IDR):", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
        
        # Menú desplegable que detona la lectura en la BD automáticamente (command=db_leer_recado) al cambiar su valor
        cmb_recados = ctk.CTkComboBox(master=vista_recados, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", command=db_leer_recado)
        cmb_recados.pack(anchor="w", padx=40, pady=(0, 10))
        
        ctk.CTkLabel(master=vista_recados, text="Mensaje del Recado:", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
        txt_contenido_recado = ctk.CTkTextbox(master=vista_recados, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", border_width=1, height=150)
        txt_contenido_recado.pack(fill="x", padx=40, pady=(0, 10))

        # ¡CORREGIDO! db_cargar_recados() se ejecuta ahora al final, cuando txt_contenido_recado ya se creó en memoria
        db_cargar_recados()  

        # --- CONSTRUCCIÓN VISUAL: VISTA ASESORÍAS ---
        ctk.CTkLabel(master=vista_asesoria, text="REGISTRAR ASESORÍA", font=("Times New Roman", 22, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(30, 10))
        
        # Uso del layout Grid interno para alinear "ID Caso" y "Fecha" uno junto al otro para ahorrar espacio
        frame_campos_ase = ctk.CTkFrame(master=vista_asesoria, fg_color="transparent")
        frame_campos_ase.pack(fill="x", padx=40, pady=(5, 5))
        
        ctk.CTkLabel(master=frame_campos_ase, text="ID Caso (IDC):", font=("Arial", 12, "bold"), text_color="#1F1711").grid(row=0, column=0, sticky="w", pady=(0,2))
        txt_id_ase = ctk.CTkEntry(master=frame_campos_ase, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=180)
        txt_id_ase.grid(row=1, column=0, sticky="w", padx=(0, 20))
        
        ctk.CTkLabel(master=frame_campos_ase, text="Fecha (DD/MM/AAAA):", font=("Arial", 12, "bold"), text_color="#1F1711").grid(row=0, column=1, sticky="w", pady=(0,2))
        txt_fecha_ase = ctk.CTkEntry(master=frame_campos_ase, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=180)
        txt_fecha_ase.grid(row=1, column=1, sticky="w")
        
        ctk.CTkLabel(master=vista_asesoria, text="Detalles de la Asesoría (CASO):", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(10, 2))
        txt_desc_ase = ctk.CTkTextbox(master=vista_asesoria, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", border_width=1, height=120)
        txt_desc_ase.pack(fill="x", padx=40, pady=(0, 15))
        ctk.CTkButton(master=vista_asesoria, text="💾 Guardar Asesoría", fg_color="#2E7D32", hover_color="#1B5E20", font=("Arial", 12, "bold"), command=db_guardar_asesoria).pack(anchor="w", padx=40)

        # --- CONSTRUCCIÓN VISUAL: VISTA AUDIENCIAS ---
        ctk.CTkLabel(master=vista_audiencia, text="AGENDAR AUDIENCIA", font=("Times New Roman", 22, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(30, 10))
        ctk.CTkLabel(master=vista_audiencia, text="ID del Caso (IDC):", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(5, 2))
        txt_id_aud = ctk.CTkEntry(master=vista_audiencia, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=250)
        txt_id_aud.pack(anchor="w", padx=40, pady=(0, 10))
        
        # Entrada para registrar la fecha y hora de la audiencia programada
        ctk.CTkLabel(master=vista_audiencia, text="Fecha y Hora:", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(5, 2))
        txt_fecha_aud = ctk.CTkEntry(master=vista_audiencia, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=250, placeholder_text="Ej. 15/08/2026 10:30 AM")
        txt_fecha_aud.pack(anchor="w", padx=40, pady=(0, 10))
        
        # Entrada para escribir el juzgado físico asignado por los tribunales
        ctk.CTkLabel(master=vista_audiencia, text="Juzgado / Sala:", font=("Arial", 12, "bold"), text_color="#1F1711").pack(anchor="w", padx=40, pady=(5, 2))
        txt_juzgado = ctk.CTkEntry(master=vista_audiencia, fg_color="#FFFFFF", text_color="#1F1711", border_color="#C2BCB4", width=350)
        txt_juzgado.pack(anchor="w", padx=40, pady=(0, 15))
        ctk.CTkButton(master=vista_audiencia, text="📅 Agendar", fg_color="#1565C0", hover_color="#0D47A1", font=("Arial", 12, "bold"), command=db_agendar_audiencia).pack(anchor="w", padx=40)
        
        # Botón rojo flotante ubicado en la esquina inferior derecha. Al usar .place() se mantiene fijo por encima del sistema de vistas.
        btn_cerrar_sesion = ctk.CTkButton(
            master=panel_derecho, text="🛑 CERRAR SESIÓN", fg_color="#B71C1C", hover_color="#9A1B1B", 
            text_color="#FFFFFF", font=("Arial", 12, "bold"), height=35, corner_radius=8, command=cerrar_sesion
        )
        btn_cerrar_sesion.place(relx=0.95, rely=0.95, anchor="se")

    # ------------------------------------------------------
    # E. GENERACIÓN DINÁMICA DE BOTONES LATERALES
    # ------------------------------------------------------
    for texto, icono in botones_lista:
        comando_boton = None
        
        # Enlaza la acción únicamente si el botón coincide con la directiva del Jefe
        if texto == "DAR DE ALTA O BAJA USUARIOS":
            comando_boton = mostrar_formulario_alta
            
        # Si el usuario es ABOGADO y el texto de la iteración actual está registrado en su diccionario de vistas
        if "ABOGADO" in rol and texto in vistas_abogado:
            # Crea una función anónima (lambda) que llama a .tkraise() para traer la ventana elegida al frente
            comando_boton = lambda v=vistas_abogado[texto]: v.tkraise()

        btn_menu = ctk.CTkButton(
            master=menu_lateral, text=f"{icono}   {texto}", anchor="w",
            text_color="#EFE7DC", fg_color="#4E342E", hover_color="#5D4037", border_color="#6D4C41",
            border_width=1, height=40, corner_radius=8, font=("Arial", 11, "bold"), command=comando_boton
