        # Función para procesar el guardado SQL (ALTA o ACTUALIZACIÓN inteligente)
        def registrar_usuario_bd():
            idu = txt_id.get().strip()
            nombre = txt_nombre.get().strip()
            contra = txt_pass.get().strip()
            rol_elegido = combo_rol.get()

            if not idu or not nombre or not contra:
                messagebox.showwarning("Campos vacíos", "Por favor, complete todos los campos para guardar.")
                return

            try:
                conexion = sqlite3.connect(RUTA_BD)
                cursor = conexion.cursor()
                
                # Verificamos si el ID ya existe en el sistema antes de insertar
                cursor.execute("SELECT NOMBRE FROM Usuarios WHERE LOWER(TRIM(IDU)) = LOWER(?)", (idu,))
                existe = cursor.fetchone()
                
                if existe:
                    # SI YA EXISTE: Pregunta de confirmación para actualización de datos
                    confirmar = messagebox.askyesno("Usuario Existente", f"El ID '{idu}' ya pertenece a '{existe[0]}'.\n¿Desea actualizar sus datos con la nueva información?")
