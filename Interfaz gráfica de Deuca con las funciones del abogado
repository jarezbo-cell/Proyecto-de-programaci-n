                conexion.close()
                mostrar_vista_inicio()
                
            except Exception as e:
                messagebox.showerror("Error de BD", f"Error inesperado: {e}")

        # Función para procesar la eliminación SQL (BAJA)
        def dar_de_baja_bd():
            idu = txt_id.get().strip()

